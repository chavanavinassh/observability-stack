{
  "title": "Observability \u2013 NOC Overview",
  "schemaVersion": 42,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "project",
        "type": "query",
        "query": "label_values(probe_success, project)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Services UP",
      "targets": [
        {
          "expr": "sum(probe_success)",
          "instant": true
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Services DOWN",
      "targets": [
        {
          "expr": "count(probe_success)-sum(probe_success)",
          "instant": true
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Website SLA 24h %",
      "targets": [
        {
          "expr": "avg_over_time(probe_success{service='website'}[24h])*100",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latency P95",
      "targets": [
        {
          "expr": "quantile_over_time(0.95, probe_duration_seconds[5m])"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 4
      }
    }
  ]
}